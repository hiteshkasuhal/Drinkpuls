{%- style -%}
.hk-section-bg-{{ section.id }} {
    background-color:{{ section.settings.background_color }};
    color:{{ section.settings.text_color }};
    }
{% if section.settings.background_image != blank %}
.hk-section-bg-{{ section.id }} {
      background-image:url({{section.settings.background_image | image_url}});
    background-size: cover;
    background-attachment: unset;
    background-repeat: no-repeat;
    background-position: center;
    }
  {% endif %}
{% if section.settings.background_image_mobile != blank %}
  @media screen and (max-width: 915px) {
    .hk-section-bg-{{ section.id }} {
      background-image:url({{section.settings.background_image_mobile | image_url}});
    }
  }
  {% endif %}
  @media screen and (max-width: 915px) {
    .hk-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top_mobile }}px;
      padding-bottom: {{ section.settings.padding_bottom_mobile }}px;
    }
  }
  @media screen and (min-width: 915px) {
    .hk-section-{{ section.id }}-padding {
      padding-top: {{ section.settings.padding_top }}px;
      padding-bottom: {{ section.settings.padding_bottom }}px;
    }
  }  
{%- endstyle -%}
<div class="hk-section-bg-{{ section.id }} hk-product {{ section.settings.custom_class }}" {% if section.settings.custom_id != blank %} id="{{ section.settings.custom_id }}" {% endif %}>
  <div class="hk-container hk-section-{{ section.id }}-padding">
    <div class="hk-product-content hk-text-{{ section.settings.text_alignment }}-desktop hk-text-{{ section.settings.text_alignment_mobile }}-mobile"> 
    <div class="hk-product-flex">
    <div class="hk-product-column hk-product-column1">
      {%- for block in section.blocks -%} 
            {%- case block.type -%} 
                {%- when 'product_media' -%} 
                    {%  render 'hk-element-product-media', block:block %}  
            {%  endcase %}
        {%  endfor %}  
    </div>
    <div class="hk-product-column hk-product-column2">
        {%- for block in section.blocks -%} 
            {%- case block.type -%} 
                {%- when 'heading' -%} 
                    {%  render 'hk-element-heading', block:block %} 
                {%- when 'richtext' -%} 
                    {%  render 'hk-element-richtext', block:block %} 
                {%- when 'image' -%} 
                    {%  render 'hk-element-image', block:block %} 
                {%- when 'liquid' -%} 
                    {%  render 'hk-element-liquid', block:block %} 
                {%- when 'icon_with_text' -%} 
                    {%  render 'hk-element-icon-with-text', block:block %} 
                {%- when 'faq' -%} 
                    {%  render 'hk-element-faq', block:block %} 
                {%- when 'options' -%} 
                    {%  render 'hk-element-options', block:block, section:section %} 
                {%- when 'checkout_button' -%} 
                    {%  render 'hk-element-checkout-button', block:block %} 
                {%- when 'icon_with_text_grid' -%} 
                    {%  render 'hk-element-icon-with-text-grid', block:block %} 
                {%- when 'variants' -%} 
                    {%  render 'hk-element-variants', block:block, section:section %} 
                {%- when 'subscription_widget' -%} 
                    {%  render 'hk-element-sub-widget', block:block %} 
                {%- when 'stock' -%} 
                    {%  render 'hk-element-stock', block:block %} 
            {%  endcase %}
        {%  endfor %}  
    </div>
    </div>
    </div>
  </div>
</div>
