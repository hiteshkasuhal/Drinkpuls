{% if template contains 'cart' %}
{% else %}
    <div class="hk-drawer-cart-bg"></div>
<div class="hk-cart-drawer hk-cart-drawer-js {{ section.settings.custom_class }}" {% if section.settings.custom_id != blank %} id="{{ section.settings.custom_id }}" {% endif %}>
  <button class="hk-mobile-cart-close"><svg xmlns="http://www.w3.org/2000/svg" width="12" height="11" viewBox="0 0 12 11" fill="none">
  <path d="M10.3613 0.936005L0.936329 10.036" stroke="black" stroke-width="1.872" stroke-linecap="round"/>
  <path d="M0.935547 0.936005L10.3605 10.036" stroke="black" stroke-width="1.872" stroke-linecap="round"/>
</svg></button>
    {% if cart.item_count > 0 %}
    <div class="hk-cart-drawer-content hk-text-left-desktop hk-text-left-mobile"> 
    <div class="hk-cart-drawer-flex">
    <div class="hk-cart-drawer-column hk-cart-drawer-column1">
        {%- for block in section.blocks -%} 
            {% if block.settings.position == 'left' %}
            {%- case block.type -%} 
                {%- when 'heading' -%} 
                    {%  render 'hk-element-heading', block:block %} 
                {%- when 'richtext' -%} 
                    {%  render 'hk-element-richtext', block:block %}  
                {%- when 'total' -%} 
                    {%  render 'hk-element-total', block:block %} 
                {%- when 'image' -%} 
                    {%  render 'hk-element-image', block:block %} 
                {%- when 'button' -%} 
                    {%  render 'hk-element-button', block:block %} 
                {%- when 'icon_with_text' -%} 
                    {%  render 'hk-element-icon-with-text', block:block %} 
                {%- when 'liquid' -%} 
                    {%  render 'hk-element-liquid', block:block %} 
                {%- when 'icon_with_text_grid' -%} 
                    {%  render 'hk-element-icon-with-text-grid', block:block %} 
                {%- when 'checkout_button' -%} 
                    {%  render 'hk-element-cart-checkout-button', block:block %} 
                {%- when 'free_shipping' -%} 
                    {%  render 'hk-element-free-shipping', block:block %} 
                {%- when 'related_products' -%} 
                    {%  render 'hk-element-related-products-cart', block:block %} 
                {%- when 'cart_items' -%} 
                    {%  render 'hk-element-cart-items', block:block %} 
                {%- when 'shipping_protection' -%} 
                    {%  render 'hk-element-shipping-protection', block:block %} 
            {%  endcase %}
            {% endif %}
        {%  endfor %}  
    </div>
    <div class="hk-cart-drawer-column hk-cart-drawer-column2">
        {%- for block in section.blocks -%} 
            {% if block.settings.position == 'right' %}
            {%- case block.type -%} 
                {%- when 'heading' -%} 
                    {%  render 'hk-element-heading', block:block %} 
                {%- when 'richtext' -%} 
                    {%  render 'hk-element-richtext', block:block %} 
                {%- when 'total' -%} 
                    {%  render 'hk-element-total', block:block %} 
                {%- when 'image' -%} 
                    {%  render 'hk-element-image', block:block %} 
                {%- when 'button' -%} 
                    {%  render 'hk-element-button', block:block %} 
                {%- when 'icon_with_text' -%} 
                    {%  render 'hk-element-icon-with-text', block:block %} 
                {%- when 'liquid' -%} 
                    {%  render 'hk-element-liquid', block:block %} 
                {%- when 'icon_with_text_grid' -%} 
                    {%  render 'hk-element-icon-with-text-grid', block:block %} 
                {%- when 'checkout_button' -%} 
                    {%  render 'hk-element-cart-checkout-button', block:block %} 
                {%- when 'free_shipping' -%} 
                    {%  render 'hk-element-free-shipping', block:block %} 
                {%- when 'related_products' -%} 
                    {%  render 'hk-element-related-products-cart', block:block %} 
                {%- when 'cart_items' -%} 
                    {%  render 'hk-element-cart-items', block:block %} 
                {%- when 'shipping_protection' -%} 
                    {%  render 'hk-element-shipping-protection', block:block %} 
            {%  endcase %}
            {% endif %}
        {%  endfor %}  
    </div>
    </div>
    </div>
{% else  %}
    
<div class="hk-cart-drawer-content hk-text-center-desktop hk-text-center-mobile empty-cart-main"> 
     
 <div class="hk-element hk-element-heading-main hk-empty-cart-title hk-global-heading">
<h1 class="hk-element-heading hk-font-heading">Your Cart Is Empty</h1>
 <div class="hk-element hk-element-button-main hk-empty-cart-button">
<div class="hk-element-button">
<a class="hk-button hk-font-body" href="#close_cart">Continue Shopping</a></div>
</div>
</div>


</div>
{% endif %}


  </div>
{% endif %}
