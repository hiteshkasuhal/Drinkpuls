
{%- for block in section.blocks -%} 
{%- case block.type -%} 
{%- when 'variant' -%}  
{% assign index = block.settings.index | minus:1 %}
{% if block.settings.active == true %}
{% assign variant = product.variants[index] %}
{%  endif %}
{%  endcase %}
{%  endfor %} 
{% capture price_content %}

{%- for block in section.blocks -%} 
{%- case block.type -%} 
{%- when 'variant' -%}  
{% assign index = block.settings.index | minus:1 %}
{% assign variant = product.variants[index] %}
{%  assign compare_price = variant.price  %}
{%  if variant.compare_at_price > variant.price %}
{%  assign compare_price = variant.compare_at_price  %}
{% endif %}
{%  assign price = variant.price  %}
{%  assign price_sub = variant.selling_plan_allocations.first.per_delivery_price %}
<span class="el-variant-trigger{% if block.settings.active == true %} el-active{% endif %}" variant_id="{{ variant.id }}"{% if block.settings.active != true %} style="display:none;"{% endif %}>
<span class="el-sub-trigger" sub_tab="1">
{{ price_sub | money }}{%  if compare_price > price_sub %} <s>{{ compare_price | money }}</s>{% endif %}
</span>
<span class="el-sub-trigger" sub_tab="2" style="display:none;">
{{ price | money }}{%  if compare_price > price %} <s>{{ compare_price | money }}</s>{% endif %}
</span>
</span>
{%  endcase %}
{%  endfor %} 
{% endcapture %}
<div class="el-element el-element-button {{ block.settings.custom_class }} el-element-{{ block.id }}"{% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id }}"{% endif %}>
<div class="el-element-button-{{ block.id }} el-font-{{ block.settings.font_type }}">
<button class="el-button el-checkout-button el-trigger-{{ section.id }} el-font-body"  variant_id="{{ variant.id }}" selling_plan="{{ variant.selling_plan_allocations.first.selling_plan.id }}">{{ block.settings.button_label }}
</button></div>
<script>$(document).on("click", '.el-trigger-{{ section.id }}', function (e) {
  e.preventDefault();

  var $btn = $(this);

  // prevent multiple clicks
  if ($btn.hasClass('el-loading')) return;

  $btn.addClass('el-loading');

  var items = [];

  // main product
  var variant_id = $btn.attr('variant_id');
  var selling_plan = $btn.attr('selling_plan');

  var item = {
    id: parseInt(variant_id),
    quantity: 1
  };

  // add selling plan if exists
  if (selling_plan) {
    item.selling_plan = parseInt(selling_plan);
  }

  items.push(item);

  // free gift
 /* var $freeGift = $('.el-element-sub-option.el-active .el-free-product-details');

  if ($freeGift.length) {

    var free_variant_id = $freeGift.attr('variant_id');

    if (free_variant_id) {
      items.push({
        id: parseInt(free_variant_id),
        quantity: 1
      });
    }
  }*/

  $.ajax({
    type: 'POST',
    url: '/cart/add.js',
    data: JSON.stringify({
      items: items
    }),
    dataType: 'json',
    contentType: 'application/json',

    success: function () {

      // open cart drawer
      $('.amp-cart').addClass('amp-cart--open');

    },

    complete: function () {
      setTimeout(function () {
        $btn.removeClass('el-loading');
      }, 500);
    }
  });

});
</script>

</div>