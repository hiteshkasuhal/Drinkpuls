{% assign shipping_product = block.settings.product %}
{% assign shipping_variant_id = shipping_product.selected_or_first_available_variant.id %}
{% assign shipping_in_cart = false %}
{% for item in cart.items %}
  {% if item.variant_id == shipping_variant_id %}
    {% assign shipping_in_cart = true %}
  {% endif %}
{% endfor %}
<div class="hk-element hk-element-shipping-protection-main {{ block.settings.custom_class }} hk-element-{{ block.id }}"{% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id }}"{% endif %}>
<div class="hk-shipping-protection-flex">
<div class="hk-shipping-protection-left">
<div class="hk-element-image">
{%  if block.settings.image != blank %}
{% if block.settings.image_mobile != blank %}
  <div class="hk-media hk-hide-mobile">
 {{ block.settings.image | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}}   
</div>
  <div class="hk-media hk-hide-desktop">
 {{ block.settings.image_mobile | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image_mobile.alt,
  widths: '375, 550, 750, 800'
}}   
</div>
{% else %}
  <div class="hk-media">
 {{ block.settings.image | image_url: width: 800 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}} 
</div>
{%  endif %}
{%  endif %}
{%  if block.settings.liquid != blank %}
<div class="hk-media hk-svg">
{{ block.settings.liquid }}
</div>
{% endif %}
</div>
<div class="hk-element-texts">
{%  if block.settings.title != blank %}
<div class="hk-element-title hk-font-{{ block.settings.font_type_title }}">{{ block.settings.title }}</div>
{% endif %}
{%  if block.settings.text != blank %}
<div class="hk-element-text hk-font-{{ block.settings.font_type_text }}">{{ block.settings.text }}</div>
{% endif %}
</div>
</div>
</div>
<div class="hk-shipping-protection-right">
<div class="hk-shipping-protection-price">+{{ shipping_product.price | money }}</div>
<div class="hk-shipping-protection-toggle">
<div class="hk-shipping-protection-toggle-wrapper{% if shipping_in_cart %} active{% endif %}"
     data-variant-id="{{ shipping_variant_id }}"><div class="hk-shipping-protection-toggle-button"></div></div>
</div>
</div>
</div>