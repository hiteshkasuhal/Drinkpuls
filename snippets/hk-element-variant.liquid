{% assign index = block.settings.index | minus:1 %}
{% assign variant = product.variants[index] %}
{%  assign compare_price = variant.price  %}
{%  if variant.compare_at_price > variant.price %}
{%  assign compare_price = variant.compare_at_price  %}
{% endif %}
{%  assign price = variant.price  %}
{%  assign price_sub = variant.selling_plan_allocations.first.per_delivery_price %}
<button class="hk-element-variant{% if block.settings.active == true %} hk-active{% endif %} hk-font-body" variant_id="{{  variant.id  }}" selling_plan="{{ variant.selling_plan_allocations.first.selling_plan.id }}">
<span class="hk-variant-inner">
{% if block.settings.badge != blank %}
<span class="hk-variant-badge">{{ block.settings.badge }}</span>
{% endif %}
{% if block.settings.title != blank %}
<span class="hk-variant-title">{{ block.settings.title }}</span>
{% endif %}
{% if block.settings.text != blank %}
<span class="hk-variant-text">{{ block.settings.text }}</span>
{% endif %}

<span class="hk-variant-price">
<span class="hk-sub-trigger" sub_tab="1">
{{ price_sub | money_without_trailing_zeros }} 
{% if compare_price > price_sub %}<s>{{ compare_price | money }}</s>{% endif %}
</span>
<span class="hk-sub-trigger" sub_tab="2" style="display:none;">
{{ price | money_without_trailing_zeros }} 
{% if compare_price > price %}<s>{{ compare_price | money }}</s>{% endif %}
</span>
</span>

{% if block.settings.image != blank %}
{% if block.settings.image_mobile != blank %}
<span class="hk-variant-image hk-hide-desktop">
 {{ block.settings.image_mobile | image_url: width: 200 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image_mobile.alt,
  widths: '375, 550, 750, 800'
}} 
</span>
<span class="hk-variant-image hk-hide-mobile">
 {{ block.settings.image | image_url: width: 200 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}} 
</span>
{% else %}
<span class="hk-variant-image">
 {{ block.settings.image | image_url: width: 200 | image_tag:
  loading: block.settings.image_loading,
  fetchpriority: block.settings.image_performance,
  alt:block.settings.image.alt,
  widths: '375, 550, 750, 800'
}} 
</span>
{% endif %}
{% endif %}
</span>
</button>