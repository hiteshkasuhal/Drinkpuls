 <div class="hk-element hk-element-heading-main {{ block.settings.custom_class }} hk-element-{{ block.id }}"{% if block.settings.custom_id != blank %} id="{{ block.settings.custom_id }}"{% endif %}>
{% if block.settings.h1 != true %}
<h2 class="hk-element-heading hk-font-{{ block.settings.font_type }}">{{ block.settings.text }}</h2>
{% else %}
<h1 class="hk-element-heading hk-font-{{ block.settings.font_type }}">{{ block.settings.text }}</h1>
{% endif %} 
</div>