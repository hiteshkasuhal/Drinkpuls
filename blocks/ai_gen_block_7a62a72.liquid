{% doc %}
  @prompt
    Create a full-width hero section with a dark navy background image. At the top center, place the PULS logo. Below the logo, add a bold headline: ‘This Isn’t Just Coffee… it’s YOUR NEW SECRET WEAPON’. Underneath, add a supporting line: ‘Protein x Creatine x Focus-boosting MCTs’, followed by smaller lighter text for: ‘Fuel your brain, body, and energy — every morning.’ and ‘Forget overpriced lattes and messy powders. This is coffee engineered for performance.’
    
    Then add a bold white callout: ‘Only 500 spots in the first drop. Don’t miss out.’ with a smaller line under it: ‘Early signups unlock the launch drop.’
    
    Directly beneath this text, add a signup form integrated with Mailchimp: rounded white input field with placeholder ‘Your Email Address’ and a yellow button labeled ‘Claim Early Access’ with a right arrow.
    
    Make sure spacing is tight and balanced vertically, and the background fills edge-to-edge with no white gap at the bottom., Create a full-width hero section with a dark navy background that fits the screen height without causing vertical or horizontal scroll. At the top center place the PULS logo. Below add the headline ‘This Isn’t Just Coffee… it’s YOUR NEW SECRET WEAPON’ in bold white text. Then add the supporting line ‘Protein x Creatine x Focus-boosting MCTs’ in medium weight, and smaller lighter lines for: ‘Fuel your brain, body, and energy — every morning.’ and ‘Forget overpriced lattes and messy powders. This is coffee engineered for performance.’
    
    After that, add a bold white callout: ‘Only 500 spots in the first drop. Don’t miss out.’ with a smaller subtext: ‘Early signups unlock the launch drop.’
    
    Directly underneath, include a Mailchimp-integrated signup form: rounded white input field with placeholder ‘Your Email Address’ and a yellow button labeled ‘Claim Early Access’ with a right arrow.
    
    Ensure all elements are centered and evenly spaced vertically, with no large gaps and no overflow causing scrollbars. The section should be fully responsive and aligned edge-to-edge., Refine the hero section. The PULS logo should appear at the top center, with responsive sizing controls so I can adjust its width and height separately, while keeping proportions correct and mobile-friendly.
    
    Below the logo, text hierarchy should match exactly:
    
    Main tagline: ‘This Isn’t Just Coffee… it’s YOUR NEW SECRET WEAPON’ in bold white, medium size, not oversized.
    
    Supporting line: ‘Protein x Creatine x Focus-boosting MCTs’ in semi-bold white, slightly smaller.
    

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    width: 100vw;
    height: 100vh;
    background-color: {{ block.settings.background_color }};
    background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
    background-size: cover;
    background-position: center;
    background-repeat: no-repeat;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    padding: 20px;
    text-align: center;
    position: relative;
    overflow: hidden;
    margin: 0;
    box-sizing: border-box;
  }

  .ai-hero-section-{{ ai_gen_id }}::before {
    content: '';
    position: absolute;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: rgba(26, 26, 46, {{ block.settings.overlay_opacity | divided_by: 100.0 }});
    z-index: 1;
  }

  .ai-hero-content-group-{{ ai_gen_id }} {
    position: relative;
    z-index: 2;
    max-width: 600px;
    width: 100%;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 16px;
    transform: translateY({{ block.settings.vertical_position }}px);
  }

  .ai-hero-logo-{{ ai_gen_id }} {
    flex-shrink: 0;
    margin-bottom: -8px;
    width: {{ block.settings.logo_width }}px;
    height: {{ block.settings.logo_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-logo-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: contain;
  }

  .ai-hero-logo-placeholder-{{ ai_gen_id }} {
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
    padding: 15px;
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-logo-placeholder-{{ ai_gen_id }} svg {
    width: 80%;
    height: 80%;
    opacity: 0.3;
  }

  .ai-hero-text-content-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 8px;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-size: {{ block.settings.headline_size }}px;
    font-weight: 700;
    color: {{ block.settings.headline_color }};
    margin: 0;
    line-height: 1.2;letter-spacing: -0.01em;
  }

  .ai-hero-subline-{{ ai_gen_id }} {
    font-size: {{ block.settings.subline_size }}px;
    font-weight: 600;
    color: {{ block.settings.subline_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-hero-body-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.body_size }}px;
    font-weight: 400;
    color: {{ block.settings.body_color }};
    margin: 0;
    line-height: 1.4;
    opacity: 0.9;
  }

  .ai-hero-callout-section-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 6px;
    margin-bottom: 8px;
  }

  .ai-hero-callout-text-{{ ai_gen_id }} {
    font-size: {{ block.settings.callout_size }}px;
    font-weight: 700;
    color: {{ block.settings.callout_color }};
    margin: 0;
    line-height: 1.3;
  }

  .ai-hero-callout-subtext-{{ ai_gen_id }} {
    font-size: {{ block.settings.callout_subtext_size }}px;
    font-weight: 400;
    color: {{ block.settings.callout_subtext_color }};
    margin: 0;
  }

  .ai-hero-form-wrapper-{{ ai_gen_id }} {
    width: 100%;
    max-width: 500px;
  }

  .ai-hero-form-{{ ai_gen_id }} {
    display: flex;
    gap: 10px;
    width: 100%;
  }

  .ai-hero-input-wrapper-{{ ai_gen_id }} {
    flex: 1;
    position: relative;
    min-width: 0;
  }

  .ai-hero-input-icon-{{ ai_gen_id }} {
    position: absolute;
    left: 16px;
    top: 50%;
    transform: translateY(-50%);
    width: 18px;
    height: 18px;
    color: {{ block.settings.input_placeholder_color }};
    z-index: 1;
  }

  .ai-hero-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 14px 18px 14px 46px;
    border: none;
    border-radius: {{ block.settings.input_border_radius }}px;
    font-size: {{ block.settings.input_font_size }}px;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
    box-sizing: border-box;
    min-width: 250px;
  }

  .ai-hero-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
    opacity: 0.7;
  }

  .ai-hero-button-{{ ai_gen_id }} {
    padding: 14px 20px;
    border: none;
    border-radius: {{ block.settings.button_border_radius }}px;
    background-color: {{ block.settings.button_color }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_font_size }}px;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    gap: 6px;
    transition: background-color 0.3s ease;
    white-space: nowrap;
    flex-shrink: 0;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_color }};
  }

  .ai-hero-button-arrow-{{ ai_gen_id }} {
    width: 16px;
    height: 16px;
  }

  .ai-hero-form-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
    margin-top: 12px;
    font-weight: 600;
    font-size: 14px;
  }

  .ai-hero-form-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
    margin-top: 12px;
    font-size: 14px;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-section-{{ ai_gen_id }} {
      padding: 15px;
    }

    .ai-hero-content-group-{{ ai_gen_id }} {
      gap: 14px;
      max-width: 100%;
      transform: translateY({{ block.settings.vertical_position | times: 0.7 }}px);
    }

    .ai-hero-logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.8 }}px;
      height: {{ block.settings.logo_height | times: 0.8 }}px;
      margin-bottom: -6px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-hero-subline-{{ ai_gen_id }} {
      font-size: {{ block.settings.subline_size | times: 0.9 }}px;
    }

    .ai-hero-body-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.body_size | times: 0.9 }}px;
    }

    .ai-hero-callout-text-{{ ai_gen_id }} {
      font-size: {{ block.settings.callout_size | times: 0.9 }}px;
    }

    .ai-hero-input-{{ ai_gen_id }} {
      font-size: {{ block.settings.input_font_size | times: 0.9 }}px;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      font-size: {{ block.settings.button_font_size | times: 0.9 }}px;
    }

    .ai-hero-form-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 12px;
    }

    .ai-hero-input-{{ ai_gen_id }} {
      min-width: auto;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      justify-content: center;
    }
  }

  @media screen and (max-width: 480px) {
    .ai-hero-content-group-{{ ai_gen_id }} {
      gap: 12px;
      transform: translateY({{ block.settings.vertical_position | times: 0.5 }}px);
    }

    .ai-hero-text-content-{{ ai_gen_id }} {
      gap: 10px;
    }

    .ai-hero-logo-{{ ai_gen_id }} {
      width: {{ block.settings.logo_width | times: 0.7 }}px;
      height: {{ block.settings.logo_height | times: 0.7 }}px;
      margin-bottom: -4px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.7 }}px;
    }
  }
{% endstyle %}

<div class="ai-hero-section-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-content-group-{{ ai_gen_id }}">
    <div class="ai-hero-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 600 }}"
          alt="{{ block.settings.logo.alt | escape }}"
          loading="lazy"
        >
      {% else %}
        <div class="ai-hero-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    <div class="ai-hero-text-content-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
      {% endif %}

      {% if block.settings.subline != blank %}
        <div class="ai-hero-subline-{{ ai_gen_id }}">{{ block.settings.subline }}</div>
      {% endif %}

      {% if block.settings.body_line_1 != blank %}
        <div class="ai-hero-body-text-{{ ai_gen_id }}">{{ block.settings.body_line_1 }}</div>
      {% endif %}

      {% if block.settings.body_line_2 != blank %}
        <div class="ai-hero-body-text-{{ ai_gen_id }}">{{ block.settings.body_line_2 }}</div>
      {% endif %}
    </div>

    <div class="ai-hero-callout-section-{{ ai_gen_id }}">
      {% if block.settings.callout_text != blank %}
        <div class="ai-hero-callout-text-{{ ai_gen_id }}">{{ block.settings.callout_text }}</div>
      {% endif %}
      {% if block.settings.callout_subtext != blank %}
        <div class="ai-hero-callout-subtext-{{ ai_gen_id }}">{{ block.settings.callout_subtext }}</div>
      {% endif %}
    </div>

    <div class="ai-hero-form-wrapper-{{ ai_gen_id }}">
      {% form 'contact' %}
        <input type="hidden" name="contact[tags]" value="newsletter">
        <div class="ai-hero-form-{{ ai_gen_id }}">
          <div class="ai-hero-input-wrapper-{{ ai_gen_id }}">
            <svg class="ai-hero-input-icon-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 4.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z" />
            </svg>
            <input
              type="email"
              name="contact[email]"
              class="ai-hero-input-{{ ai_gen_id }}"
              value="{{ form.email }}"
              placeholder="{{ block.settings.email_placeholder }}"
              aria-required="true"
              autocorrect="off"
              autocapitalize="off"
              autocomplete="email"
              {% if form.errors %}
                aria-invalid="true"
                aria-describedby="ai-hero-form-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-hero-form-success-{{ ai_gen_id }}"
              {% endif %}required
            >
          </div>
          <button type="submit" class="ai-hero-button-{{ ai_gen_id }}">
            {{ block.settings.button_text }}<svg class="ai-hero-button-arrow-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 8l4 4m0 0l-4 4m4-4H3" />
            </svg>
          </button>
        </div>
        {% if form.errors %}
          <div id="ai-hero-form-error-{{ ai_gen_id }}" class="ai-hero-form-error-{{ ai_gen_id }}">
            {% if block.settings.error_message != blank %}
              {{ block.settings.error_message }}
            {% else %}
              {{ form.errors.messages.email }}
            {% endif %}
          </div>
        {% endif %}{% if form.posted_successfully? %}
          <div id="ai-hero-form-success-{{ ai_gen_id }}" class="ai-hero-form-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</div>

