{% doc %}
  @prompt
    Create a full-width hero section with a dark navy background image. At the top center, place the PULS logo. Below the logo, add a bold headline: ‘This Isn’t Just Coffee… it’s YOUR NEW SECRET WEAPON’. Underneath, add a supporting line: ‘Protein x Creatine x Focus-boosting MCTs’, followed by smaller lighter text for: ‘Fuel your brain, body, and energy — every morning.’ and ‘Forget overpriced lattes and messy powders. This is coffee engineered for performance.’
    
    Then add a bold white callout: ‘Only 500 spots in the first drop. Don’t miss out.’ with a smaller line under it: ‘Early signups unlock the launch drop.’
    
    Directly beneath this text, add a signup form integrated with Mailchimp: rounded white input field with placeholder ‘Your Email Address’ and a yellow button labeled ‘Claim Early Access’ with a right arrow.
    
    Make sure spacing is tight and balanced vertically, and the background fills edge-to-edge with no white gap at the bottom., Create a full-width hero section with a dark navy background that fits the screen height without causing vertical or horizontal scroll. At the top center place the PULS logo. Below add the headline ‘This Isn’t Just Coffee… it’s YOUR NEW SECRET WEAPON’ in bold white text. Then add the supporting line ‘Protein x Creatine x Focus-boosting MCTs’ in medium weight, and smaller lighter lines for: ‘Fuel your brain, body, and energy — every morning.’ and ‘Forget overpriced lattes and messy powders. This is coffee engineered for performance.’
    
    After that, add a bold white callout: ‘Only 500 spots in the first drop. Don’t miss out.’ with a smaller subtext: ‘Early signups unlock the launch drop.’
    
    Directly underneath, include a Mailchimp-integrated signup form: rounded white input field with placeholder ‘Your Email Address’ and a yellow button labeled ‘Claim Early Access’ with a right arrow.
    
    Ensure all elements are centered and evenly spaced vertically, with no large gaps and no overflow causing scrollbars. The section should be fully responsive, add to customizer adjust vertical layout of the logo and contents, gap from logo to texts. adjust gap per content. adjust form and button text size. add mail icon on form before the text. arrow on claim early access must be longer. add ability to adjust form success and error message, vertical layout needs to be fined tuned not top center bottom. email field should be longer. arrow on claim early access must be longer. add the ability to choose font, adjust weight, line height, letter spacing.,

{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-section-{{ ai_gen_id }} {
    width: 100%;
    min-height: 100vh;
    background-color: {{ block.settings.background_color }};
    {% if block.settings.background_image %}
      background-image: url('{{ block.settings.background_image | image_url: width: 2000 }}');
      background-size: cover;
      background-position: center;
      background-repeat: no-repeat;
    {% endif %}
    display: flex;
    flex-direction: column;
    justify-content: center;
    align-items: center;
    padding: {{ block.settings.section_padding_top }}px 20px {{ block.settings.section_padding_bottom }}px;
    position: relative;
    overflow: hidden;
  }

  .ai-hero-content-{{ ai_gen_id }} {
    max-width: 600px;
    width: 100%;
    text-align: center;
    z-index: 2;
    margin-top: {{ block.settings.content_offset_top }}px;
    margin-bottom: {{ block.settings.content_offset_bottom }}px;
  }

  .ai-hero-logo-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.logo_gap }}px;
  }

  .ai-hero-logo-{{ ai_gen_id }} img {
    max-width: {{ block.settings.logo_width }}px;
    height: auto;
  }

  .ai-hero-logo-placeholder-{{ ai_gen_id }} {
    width: {{ block.settings.logo_width }}px;
    height: 80px;
    margin: 0 auto;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(255, 255, 255, 0.1);
    border-radius: 8px;
  }

  .ai-hero-logo-placeholder-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    opacity: 0.5;
  }

  .ai-hero-headline-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.headline_weight }};
    font-size: {{ block.settings.headline_size }}px;
    color: {{ block.settings.headline_color }};
    margin: 0 0 {{ block.settings.headline_gap }}px;
    line-height: {{ block.settings.headline_line_height }};
    letter-spacing: {{ block.settings.headline_letter_spacing }}px;}

  .ai-hero-supporting-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.supporting_weight }};
    font-size: {{ block.settings.supporting_size }}px;
    color: {{ block.settings.supporting_color }};
    margin: 0 0 {{ block.settings.supporting_gap }}px;
    line-height: {{ block.settings.supporting_line_height }};
    letter-spacing: {{ block.settings.supporting_letter_spacing }}px;
  }

  .ai-hero-description-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.description_weight }};
    font-size: {{ block.settings.description_size }}px;
    color: {{ block.settings.description_color }};
    margin: 0 0 {{ block.settings.description_gap }}px;
    line-height: {{ block.settings.description_line_height }};
    letter-spacing: {{ block.settings.description_letter_spacing }}px;
  }

  .ai-hero-callout-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.callout_weight }};
    font-size: {{ block.settings.callout_size }}px;
    color: {{ block.settings.callout_color }};
    margin: 0 0 {{ block.settings.callout_gap }}px;
    line-height: {{ block.settings.callout_line_height }};
    letter-spacing: {{ block.settings.callout_letter_spacing }}px;
  }

  .ai-hero-subtext-{{ ai_gen_id }} {
    font-family: 'Montserrat', sans-serif;
    font-weight: {{ block.settings.subtext_weight }};
    font-size: {{ block.settings.subtext_size }}px;
    color: {{ block.settings.subtext_color }};
    margin: 0 0 {{ block.settings.subtext_gap }}px;
    line-height: {{ block.settings.subtext_line_height }};
    letter-spacing: {{ block.settings.subtext_letter_spacing }}px;
  }

  .ai-hero-form-wrapper-{{ ai_gen_id }} {
    margin-top: {{ block.settings.form_gap }}px;
  }

  .ai-hero-form-{{ ai_gen_id }} {
    display: flex;
    gap: 12px;
    max-width: 500px;
    width: 100%;
    margin: 0 auto;
  }

  .ai-hero-input-wrapper-{{ ai_gen_id }} {
    flex: 2;
    position: relative;
    display: flex;
    align-items: center;
  }

  .ai-hero-mail-icon-{{ ai_gen_id }} {
    position: absolute;
    left: 16px;
    width: 20px;
    height: 20px;
    color: {{ block.settings.input_placeholder_color }};
    z-index: 1;
  }

  .ai-hero-input-{{ ai_gen_id }} {
    width: 100%;
    padding: 16px 20px 16px 50px;
    border: none;
    border-radius: {{ block.settings.input_radius }}px;
    font-size: {{ block.settings.form_text_size }}px;
    font-family: 'Montserrat', sans-serif;
    background-color: {{ block.settings.input_background }};
    color: {{ block.settings.input_text_color }};
  }

  .ai-hero-input-{{ ai_gen_id }}::placeholder {
    color: {{ block.settings.input_placeholder_color }};
  }

  .ai-hero-button-{{ ai_gen_id }} {
    flex: 1;
    padding: 16px 24px;
    border: none;
    border-radius: {{ block.settings.button_radius }}px;
    background-color: {{ block.settings.button_background }};
    color: {{ block.settings.button_text_color }};
    font-size: {{ block.settings.button_text_size }}px;
    font-family: 'Montserrat', sans-serif;
    font-weight: 600;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    transition: background-color 0.3s ease;
    white-space: nowrap;
  }

  .ai-hero-button-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.button_hover_background }};
  }

  .ai-hero-arrow-{{ ai_gen_id }} {
    width: 24px;
    height: 24px;
  }

  .ai-hero-message-{{ ai_gen_id }} {
    margin-top: 16px;
    font-size: {{ block.settings.message_text_size }}px;
    font-family: 'Montserrat', sans-serif;
    text-align: center;
  }

  .ai-hero-success-{{ ai_gen_id }} {
    color: {{ block.settings.success_color }};
  }

  .ai-hero-error-{{ ai_gen_id }} {
    color: {{ block.settings.error_color }};
  }

  .ai-hero-background-placeholder-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    background: linear-gradient(135deg, #1a237e 0%, #283593 100%);
    z-index: 1;
  }

  .ai-hero-empty-state-{{ ai_gen_id }} {
    position: absolute;
    bottom: 20px;
    left: 50%;
    transform: translateX(-50%);
    color: rgba(255, 255, 255, 0.7);
    font-size: 14px;
    font-family: 'Montserrat', sans-serif;
    z-index: 3;
  }

  @media screen and (max-width: 768px) {
    .ai-hero-section-{{ ai_gen_id }} {
      padding: {{ block.settings.section_padding_top | times: 0.7 }}px 16px {{ block.settings.section_padding_bottom | times: 0.7 }}px;
    }

    .ai-hero-content-{{ ai_gen_id }} {
      margin-top: {{ block.settings.content_offset_top | times: 0.5 }}px;
      margin-bottom: {{ block.settings.content_offset_bottom | times: 0.5 }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      font-size: {{ block.settings.headline_size | times: 0.8 }}px;
    }

    .ai-hero-supporting-{{ ai_gen_id }} {
      font-size: {{ block.settings.supporting_size | times: 0.9 }}px;
    }

    .ai-hero-form-{{ ai_gen_id }} {
      flex-direction: column;
      gap: 12px;
    }

    .ai-hero-input-wrapper-{{ ai_gen_id }} {
      flex: 1;
    }

    .ai-hero-button-{{ ai_gen_id }} {
      flex: 1;
      justify-content: center;
    }

    .ai-hero-logo-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.logo_gap | times: 0.8 }}px;
    }

    .ai-hero-headline-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.headline_gap | times: 0.8 }}px;
    }

    .ai-hero-supporting-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.supporting_gap | times: 0.8 }}px;
    }

    .ai-hero-description-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.description_gap | times: 0.8 }}px;
    }

    .ai-hero-callout-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.callout_gap | times: 0.8 }}px;
    }

    .ai-hero-subtext-{{ ai_gen_id }} {
      margin-bottom: {{ block.settings.subtext_gap | times: 0.8 }}px;
    }
  }
{% endstyle %}

<hero-section-{{ ai_gen_id }}
  class="ai-hero-section-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  {% unless block.settings.background_image %}
    <div class="ai-hero-background-placeholder-{{ ai_gen_id }}"></div><div class="ai-hero-empty-state-{{ ai_gen_id }}">
      Next, add a background image
    </div>
  {% endunless %}

  <div class="ai-hero-content-{{ ai_gen_id }}">
    <div class="ai-hero-logo-{{ ai_gen_id }}">
      {% if block.settings.logo %}
        <img
          src="{{ block.settings.logo | image_url: width: 400 }}"
          alt="{{ block.settings.logo.alt | escape }}"
          loading="lazy"
          width="{{ block.settings.logo.width }}"
          height="{{ block.settings.logo.height }}"
        >
      {% else %}
        <div class="ai-hero-logo-placeholder-{{ ai_gen_id }}">
          {{ 'image' | placeholder_svg_tag }}
        </div>
      {% endif %}
    </div>

    {% if block.settings.headline != blank %}
      <h1 class="ai-hero-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h1>
    {% endif %}

    {% if block.settings.supporting_text != blank %}
      <p class="ai-hero-supporting-{{ ai_gen_id }}">{{ block.settings.supporting_text }}</p>
    {% endif %}

    {% if block.settings.description != blank %}
      <div class="ai-hero-description-{{ ai_gen_id }}">{{ block.settings.description }}</div>
    {% endif %}

    {% if block.settings.callout != blank %}
      <p class="ai-hero-callout-{{ ai_gen_id }}">{{ block.settings.callout }}</p>
    {% endif %}

    {% if block.settings.subtext != blank %}
      <p class="ai-hero-subtext-{{ ai_gen_id }}">{{ block.settings.subtext }}</p>
    {% endif %}

    <div class="ai-hero-form-wrapper-{{ ai_gen_id }}">
      {% form 'contact' %}
        <div class="ai-hero-form-{{ ai_gen_id }}">
          <div class="ai-hero-input-wrapper-{{ ai_gen_id }}">
            <svg class="ai-hero-mail-icon-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/>
              <polyline points="22,6 12,13 2,6"/>
            </svg>
            <input
              type="email"
              name="contact[email]"
              class="ai-hero-input-{{ ai_gen_id }}"
              placeholder="{{ block.settings.input_placeholder }}"
              required
              aria-label="Email address"
              {% if form.errors %}
                aria-invalid="true"aria-describedby="ai-hero-error-{{ ai_gen_id }}"
              {% endif %}
              {% if form.posted_successfully? %}
                aria-describedby="ai-hero-success-{{ ai_gen_id }}"
              {% endif %}
            >
          </div>
          <button
            type="submit"
            class="ai-hero-button-{{ ai_gen_id }}"
          >
            {{ block.settings.button_text }}
            <svg class="ai-hero-arrow-{{ ai_gen_id }}" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
              <path d="M3 12h18"/>
              <path d="M15 6l6 6-6 6"/>
            </svg>
          </button>
        </div>

        {% if form.errors %}
          <div id="ai-hero-error-{{ ai_gen_id }}" class="ai-hero-message-{{ ai_gen_id }} ai-hero-error-{{ ai_gen_id }}">
            {{ block.settings.error_message }}
          </div>
        {% endif %}

        {% if form.posted_successfully? %}
          <div id="ai-hero-success-{{ ai_gen_id }}" class="ai-hero-message-{{ ai_gen_id }} ai-hero-success-{{ ai_gen_id }}">
            {{ block.settings.success_message }}
          </div>
        {% endif %}
      {% endform %}
    </div>
  </div>
</hero-section-{{ ai_gen_id }}>

<script>
(function() {
  class HeroSection{{ ai_gen_id }} extends HTMLElement {
    constructor() {
      super();
    }

    connectedCallback() {
      this.form = this.querySelector('form');
      if (this.form) {
        this.form.addEventListener('submit', this.handleSubmit.bind(this));
      }
    }

    handleSubmit(event) {
      const email = this.form.querySelector('input[type="email"]').value;
      if (!email) {
        event.preventDefault();
        return;
      }
    }
  }

  customElements.define('hero-section-{{ ai_gen_id }}', HeroSection{{ ai_gen_id }});
})();
</script>

