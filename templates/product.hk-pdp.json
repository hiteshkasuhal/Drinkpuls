        "faq_bQF6Gm": {
          "type": "faq",
          "settings": {
            "question": "100mg Arabica coffee caffeine",
            "answer": "<p>Arabica coffee provides a smoother caffeine release compared to synthetic sources.At 100mg, it increases alertness and reaction time by blocking adenosine receptors in the brain - helping you feel awake, focused, and mentally sharp without overstimulation or jitters.</p>",
            "font_type": "body",
            "font_type_answer": "body",
            "position": "left",
