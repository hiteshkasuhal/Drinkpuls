          }
        },
        "faq_qWzLDY": {
          "type": "faq",
          "settings": {
            "question": "10g Whey protein",
            "answer": "<p>Whey protein is rapidly absorbed and rich in essential amino acids, including leucine - a key trigger for muscle protein synthesis.In PULS, it helps support muscle recovery, lean mass, and satiety, while also slowing caffeine absorption for more stable energy.</p>",
            "font_type": "body",
            "font_type_answer": "body",
